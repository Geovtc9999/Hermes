# Hermes — dev local (docker-compose.local.yml)
# Copier en .env :  copy .env.local.example .env

DATABASE_URL=postgresql://hermes:hermes_local@127.0.0.1:54333/hermes

EMBED_MODEL=intfloat/multilingual-e5-large
EMBED_DIM=1024
EMBED_CACHE_DIR=./data/models

S3_ENDPOINT=127.0.0.1:9000
S3_ACCESS_KEY=hermes
S3_SECRET_KEY=hermes_local_secret
S3_SECURE=false
S3_BUCKET=cegid-sources

ANTHROPIC_API_KEY=
ANSWER_MODEL=claude-opus-4-8

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

CHUNK_SIZE=1200
CHUNK_OVERLAP=200

TS_CONFIG=french
RERANK_ENABLED=true
RERANK_MODEL=jinaai/jina-reranker-v2-base-multilingual

ROLE_POLICY={}
PERMISSIONS_DEFAULT=allow
