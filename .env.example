# --- Hermes : configuration (copier en .env ou définir dans Coolify) ---

# PostgreSQL / pgvector (instance postgres18-recette, réseau Docker recette)
# Hôte = nom du conteneur Postgres sur le réseau recette.
DATABASE_URL=postgresql://postgres:CHANGEME@ysprg0oqzl86voh0kv0u6b6q:5432/postgres

# Embeddings locaux (fastembed) — aucune clé externe requise
EMBED_MODEL=intfloat/multilingual-e5-large
EMBED_DIM=1024
EMBED_CACHE_DIR=/data/models

# Stockage objet (MinIO) — corpus cegid-sources, réseau recette
S3_ENDPOINT=minio-r625prgazwx67rtb157fa316:9000
S3_ACCESS_KEY=CHANGEME
S3_SECRET_KEY=CHANGEME
S3_SECURE=false
S3_BUCKET=cegid-sources

# Réponse LLM (Claude) — optionnel ; sans clé, /query renvoie les extraits cités
ANTHROPIC_API_KEY=
ANSWER_MODEL=claude-opus-4-8

# Observabilité Langfuse — optionnel
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse-bwe2hfqcraro7006299144iv:3000

# Ingestion
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
